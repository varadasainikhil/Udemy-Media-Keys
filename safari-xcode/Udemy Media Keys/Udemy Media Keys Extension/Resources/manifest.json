{
  "manifest_version": 3,
  "name": "Udemy Media Keys",
  "version": "1.0",
  "description": "Use keyboard media keys to play/pause, rewind, and skip forward on Udemy.",
  "icons": {
    "48": "images/icon-48.png",
    "64": "images/icon-64.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png",
    "512": "images/icon-512.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.udemy.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
