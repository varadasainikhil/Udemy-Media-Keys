{
  "manifest_version": 3,
  "name": "Udemy Media Keys",
  "version": "1.0",
  "description": "Use keyboard media keys to play/pause, rewind, and skip forward on Udemy.",
  "icons": {
    "16": "udemy-keyboard-playback-appicon.png",
    "48": "udemy-keyboard-playback-appicon.png",
    "128": "udemy-keyboard-playback-appicon.png"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://*.udemy.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
